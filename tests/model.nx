imp open.file();

// ─────────────────────────────────────────────
// Step 1: Generate synthetic binary dataset
// 100 samples, 2 features, label in col 2
// Class 0: feature values around 1.0-2.0
// Class 1: feature values around 3.0-4.0
// ─────────────────────────────────────────────
open.file("tests/train_data.csv", write, "1.2,1.5,0\n1.8,1.1,0\n1.5,1.9,0\n2.0,1.3,0\n1.1,2.0,0\n1.7,1.6,0\n1.3,1.4,0\n2.1,1.8,0\n1.6,1.2,0\n1.9,1.7,0\n1.4,2.1,0\n2.2,1.5,0\n1.0,1.8,0\n1.8,2.0,0\n2.0,2.2,0\n1.5,1.3,0\n1.2,1.9,0\n1.7,2.1,0\n2.1,1.4,0\n1.9,1.6,0\n3.1,3.5,1\n3.8,3.1,1\n3.5,3.9,1\n4.0,3.3,1\n3.1,4.0,1\n3.7,3.6,1\n3.3,3.4,1\n4.1,3.8,1\n3.6,3.2,1\n3.9,3.7,1\n3.4,4.1,1\n4.2,3.5,1\n3.0,3.8,1\n3.8,4.0,1\n4.0,4.2,1\n3.5,3.3,1\n3.2,3.9,1\n3.7,4.1,1\n4.1,3.4,1\n3.9,3.6,1\n1.3,1.6,0\n1.9,1.2,0\n1.6,2.0,0\n2.1,1.4,0\n1.2,2.1,0\n1.8,1.7,0\n1.4,1.5,0\n2.2,1.9,0\n1.7,1.3,0\n2.0,1.8,0\n3.2,3.6,1\n3.9,3.2,1\n3.6,4.0,1\n4.1,3.4,1\n3.2,4.1,1\n3.8,3.7,1\n3.4,3.5,1\n4.2,3.9,1\n3.7,3.3,1\n4.0,3.8,1\n");

// ─────────────────────────────────────────────
// Step 2: Load and prepare data
// ─────────────────────────────────────────────
tensor raw = read_csv("tests/train_data.csv", 0);

int total_rows = csv_rows(raw);
int total_cols = csv_cols(raw);
print(total_rows);
print(total_cols);

// Split features (cols 0,1) and labels (col 2)
tensor X = csv_slice(raw, 0, 2);
tensor y = csv_col(raw, 2);

// Normalize features
tensor X_norm = normalize(X);

// ─────────────────────────────────────────────
// Step 3: Train / test split (80/20)
// ─────────────────────────────────────────────
tensor X_train = train_split(X_norm, 0.8);
tensor X_test  = test_split(X_norm,  0.8);
tensor y_train = train_split(y, 0.8);
tensor y_test  = test_split(y,  0.8);

int n_train = csv_rows(X_train);
int n_test  = csv_rows(X_test);
print(n_train);
print(n_test);

// ─────────────────────────────────────────────
// Step 4: Train logistic regression model
// ─────────────────────────────────────────────
tensor model = LoRe(200, 0.1);
fit(model, X_train, y_train);

// ─────────────────────────────────────────────
// Step 5: Evaluate
// ─────────────────────────────────────────────
tensor train_pred = predict(model, X_train);
tensor test_pred  = predict(model, X_test);

double train_acc = accuracy(train_pred, y_train);
double test_acc  = accuracy(test_pred,  y_test);

print(train_acc);
print(test_acc);

// Confusion matrix on test set
tensor conf = confusion(test_pred, y_test);
print(conf);

// Model weights and bias
tensor w = weights(model);
double b = bias(model);
print(w);
print(b);

// ─────────────────────────────────────────────
// Step 6: Save predictions
// ─────────────────────────────────────────────
write_csv("tests/predictions.csv", test_pred);
